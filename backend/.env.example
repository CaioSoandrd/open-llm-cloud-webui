# Chaves de API (configure com suas chaves reais)
OPENAI_API_KEY=sk-sua-chave-openai-aqui
DEEPINFRA_API_KEY=sua-chave-deepinfra-aqui
OPENROUTER_API_KEY=sua-chave-openrouter-aqui

# URL do Frontend (Vercel) - para CORS
# Em produção: https://seu-projeto.vercel.app
# Em desenvolvimento local:
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5500

# Porta do servidor (o Render define automaticamente)
PORT=3001
